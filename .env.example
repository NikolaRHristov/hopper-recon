# Hopper Recon — example environment file.
#
# Copy to `.env` (next to docker-compose.yml). docker-compose.yml loads it
# via env_file with required: false, so an absent .env is fine in dev.
#
# Booleans are literal strings — set "true" verbatim, anything else is false.

# ── Engine listen / database ─────────────────────────────────────────────
# Where the long-running engine binds inside its container. The compose file
# binds host 127.0.0.1:9119 → container 8080; only override if you've changed
# the compose port mapping too.
HOPPER_ADDR=:8080
HOPPER_DB_PATH=/data/scans.db

# ── Web → Engine ─────────────────────────────────────────────────────────
# Where the Next.js dashboard finds the engine. In compose this is
# `http://engine:8080` (already set in docker-compose.yml). For `npm run dev`
# against a host-bound engine the default `http://127.0.0.1:9119` works.
# ENGINE_URL=http://engine:8080

# ── Scope ─────────────────────────────────────────────────────────────────
# Comma-separated list of apex domains. When set, the engine refuses /scan
# (and MCP tool calls) for any target not equal to or under one of these
# apexes. Off-scope returns HTTP 403 + an audit log row. Unset means "scan
# anything" — the dashboard then shows a persistent banner reminding the
# operator to run only against authorized targets.
# HOPPER_ALLOWED_DOMAINS=example.com,example.org

# ── Blocklist override (rarely used) ─────────────────────────────────────
# Active probes against *.gov / *.mil / *.gouv.fr / *.gov.uk / *.go.jp /
# *.gc.ca / *.gov.au are refused by default. Both vars must be set non-empty
# to take effect — a typo'd reason ("yes") doesn't accidentally disable
# protection. Override decisions are recorded in audit_log.
# HOPPER_OVERRIDE_BLOCKLIST=true
# HOPPER_BLOCKLIST_OVERRIDE_REASON=Pentest engagement #1234, written authorization on file

# ── Litestream cloud replica (optional) ──────────────────────────────────
# By default `litestream.yml` replicates to a local file volume — fine for
# "I rm'd the DB by accident", not real DR. To stream WAL frames to S3 / R2
# / Azure Blob / GCS, edit litestream.yml to uncomment the matching block
# and supply the keys here. Both Litestream sidecars pick this file up.

# Common across S3-compatible providers (R2, S3):
# LITESTREAM_BUCKET=hopper-recon-scans
# LITESTREAM_ACCESS_KEY_ID=
# LITESTREAM_SECRET_ACCESS_KEY=

# Cloudflare R2:
# R2_ACCOUNT_ID=

# AWS S3:
# AWS_REGION=us-east-1

# Azure Blob:
# AZURE_STORAGE_ACCOUNT=
# AZURE_STORAGE_KEY=

# GCS uses application-default credentials (service account JSON mounted into
# the litestream container); no env vars needed.
